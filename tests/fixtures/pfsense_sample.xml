<?xml version="1.0"?>
<pfsense>
  <version>23.3</version>
  <system>
    <hostname>edge-pf</hostname>
    <domain>example.local</domain>
    <defaultgw4>WAN_GW</defaultgw4>
  </system>
  <interfaces>
    <wan>
      <enable></enable>
      <if>em0</if>
      <ipaddr>203.0.113.2</ipaddr>
      <subnet>29</subnet>
      <gateway>WAN_GW</gateway>
      <descr><![CDATA[Internet]]></descr>
    </wan>
    <lan>
      <enable></enable>
      <if>em1</if>
      <ipaddr>10.0.0.1</ipaddr>
      <subnet>16</subnet>
      <descr><![CDATA[LAN]]></descr>
    </lan>
    <opt1>
      <enable></enable>
      <if>em1.30</if>
      <ipaddr>192.168.30.1</ipaddr>
      <subnet>24</subnet>
      <descr><![CDATA[DMZ]]></descr>
    </opt1>
  </interfaces>
  <vlans>
    <vlan>
      <if>em1</if>
      <tag>30</tag>
      <vlanif>em1.30</vlanif>
      <descr></descr>
    </vlan>
  </vlans>
  <gateways>
    <gateway_item>
      <interface>wan</interface>
      <gateway>203.0.113.1</gateway>
      <name>WAN_GW</name>
      <ipprotocol>inet</ipprotocol>
      <descr></descr>
    </gateway_item>
    <gateway_item>
      <interface>lan</interface>
      <gateway>10.0.0.254</gateway>
      <name>LAB_GW</name>
      <ipprotocol>inet</ipprotocol>
      <descr></descr>
    </gateway_item>
  </gateways>
  <staticroutes>
    <route>
      <network>10.9.0.0/16</network>
      <gateway>LAB_GW</gateway>
      <descr></descr>
    </route>
  </staticroutes>
  <aliases>
    <alias>
      <name>WebServers</name>
      <type>host</type>
      <address>10.0.1.10 10.0.1.11</address>
      <descr><![CDATA[web farm]]></descr>
    </alias>
    <alias>
      <name>AdminNets</name>
      <type>network</type>
      <address>10.0.2.0/24</address>
      <descr></descr>
    </alias>
    <alias>
      <name>WebPorts</name>
      <type>port</type>
      <address>80 443 8000:8080</address>
      <descr></descr>
    </alias>
    <alias>
      <name>BadList</name>
      <type>urltable</type>
      <address>https://example.com/list.txt</address>
      <descr></descr>
    </alias>
  </aliases>
  <filter>
    <rule>
      <type>pass</type>
      <interface>wan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>tcp</protocol>
      <source><any></any></source>
      <destination>
        <address>WebServers</address>
        <port>WebPorts</port>
      </destination>
      <descr><![CDATA[Allow web]]></descr>
      <log></log>
    </rule>
    <rule>
      <type>pass</type>
      <interface>wan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>icmp</protocol>
      <icmptype>echoreq</icmptype>
      <source><any></any></source>
      <destination><network>wanip</network></destination>
      <descr></descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet</ipprotocol>
      <source><network>lan</network></source>
      <destination><any></any></destination>
      <descr><![CDATA[LAN out]]></descr>
    </rule>
    <rule>
      <type>block</type>
      <interface>lan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>tcp/udp</protocol>
      <source><network>lan</network></source>
      <destination>
        <not></not>
        <address>AdminNets</address>
        <port>53</port>
      </destination>
      <descr><![CDATA[No external DNS]]></descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>tcp</protocol>
      <source><network>lan</network></source>
      <destination>
        <address>198.51.100.77</address>
        <port>22</port>
      </destination>
      <descr><![CDATA[ssh out]]></descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet</ipprotocol>
      <gateway>WAN_GW</gateway>
      <source><network>lan</network></source>
      <destination><any></any></destination>
      <descr><![CDATA[pbr]]></descr>
      <disabled></disabled>
    </rule>
    <rule>
      <type>pass</type>
      <floating>yes</floating>
      <interface>wan,lan</interface>
      <ipprotocol>inet</ipprotocol>
      <protocol>udp</protocol>
      <source><any></any></source>
      <destination><any></any><port>123</port></destination>
      <descr><![CDATA[ntp everywhere]]></descr>
    </rule>
    <rule>
      <type>pass</type>
      <interface>lan</interface>
      <ipprotocol>inet6</ipprotocol>
      <source><any></any></source>
      <destination><any></any></destination>
      <descr></descr>
    </rule>
  </filter>
  <nat>
    <outbound>
      <mode>automatic</mode>
    </outbound>
    <rule>
      <protocol>tcp</protocol>
      <interface>wan</interface>
      <source><any></any></source>
      <destination>
        <network>wanip</network>
        <port>443</port>
      </destination>
      <target>10.0.1.10</target>
      <local-port>8443</local-port>
      <descr><![CDATA[web dnat]]></descr>
    </rule>
    <onetoone>
      <external>203.0.113.4</external>
      <interface>wan</interface>
      <source><address>10.0.1.11</address></source>
      <destination><any></any></destination>
      <descr></descr>
    </onetoone>
  </nat>
  <dhcpd>
    <lan>
      <enable></enable>
      <range><from>10.0.0.100</from><to>10.0.0.199</to></range>
    </lan>
  </dhcpd>
  <openvpn>
    <openvpn-server>
      <vpnid>1</vpnid>
      <mode>server_user</mode>
    </openvpn-server>
  </openvpn>
  <ipsec>
    <phase1>
      <ikeid>1</ikeid>
      <remote-gateway>198.51.100.9</remote-gateway>
    </phase1>
  </ipsec>
  <widgets>
    <sequence>system_information:col1:open</sequence>
  </widgets>
</pfsense>
